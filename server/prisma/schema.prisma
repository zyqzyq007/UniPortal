// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Change to "postgresql" for production
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  password      String
  last_login    DateTime?
  created_at    DateTime       @default(now())
  test_projects TestProject[]
  software_items SoftwareItem[]
}

model TestProject {
  project_id     String         @id @default(uuid())
  name           String
  description    String?
  path           String?        // Legacy field, might be removed later
  created_at     DateTime       @default(now())
  updated_at     DateTime       @default(now()) @updatedAt
  item_count     Int            @default(0)
  last_upload_at DateTime?
  
  owner          User           @relation(fields: [owner_id], references: [id])
  owner_id       String
  software_items SoftwareItem[]
  
  @@map("test_projects")
}

model SoftwareItem {
  item_id     String      @id @default(uuid())
  name        String
  description String?     // Added description field
  version     String?
  file_path   String
  file_size   BigInt
  uploaded_at DateTime    @default(now())
  
  project     TestProject @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  project_id  String
  
  created_by_user User    @relation(fields: [created_by], references: [id])
  created_by      String

  @@map("software_items")
  @@index([project_id])
  @@index([name])
  @@index([uploaded_at(sort: Desc)])
}
