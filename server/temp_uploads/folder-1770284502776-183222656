# ================================
# Build stage for Pynguin
# ================================
FROM python:3.10.14-slim-bullseye AS build
MAINTAINER Stephan Lukasczyk <stephan@lukasczyk.me>
ENV POETRY_VERSION "1.1.13"

WORKDIR /pynguin-build

# 防止生成 .pyc 文件；方便实时日志输出
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1

# 使用清华源（加速 pip、poetry）
ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_INDEX_URL=${PIP_INDEX_URL}
RUN pip config set global.index-url ${PIP_INDEX_URL}

# 复制项目代码
COPY . .

# 升级 pip，并使用清华源
RUN pip install --upgrade pip -i ${PIP_INDEX_URL}

# 安装 poetry 并构建
RUN pip install poetry==${POETRY_VERSION} -i ${PIP_INDEX_URL} \
    && poetry config virtualenvs.create false \
    && poetry config repositories.tuna ${PIP_INDEX_URL} \
    && poetry build

# ================================
# Execution stage for Pynguin
# ================================
FROM python:3.10.14-slim-bullseye AS execute

# 使用清华源（执行阶段也要设置）
ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_INDEX_URL=${PIP_INDEX_URL}
RUN pip config set global.index-url ${PIP_INDEX_URL}

# 基本环境变量
ENV PYNGUIN_VERSION "0.19.0"
ENV PYNGUIN_DANGER_AWARE ""
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1
ENV PYTHONHASHSEED 0

WORKDIR /pynguin

# 拷贝构建产物
COPY --from=build /pynguin-build/dist/pynguin-$PYNGUIN_VERSION.tar.gz .
COPY --from=build /pynguin-build/pynguin-docker.sh .

# # 安装 Pynguin 包
# RUN pip install /pynguin/pynguin-$PYNGUIN_VERSION.tar.gz -i ${PIP_INDEX_URL}

# RUN pip install 'volcengine-python-sdk[ark]' -i ${PIP_INDEX_URL} && \
#     pip install --upgrade 'volcengine-python-sdk[ark]' -i ${PIP_INDEX_URL}

# RUN pip install --force-reinstall "h11==0.14.0" -i ${PIP_INDEX_URL}

# 安装 Pynguin 包
RUN pip install /pynguin/pynguin-$PYNGUIN_VERSION.tar.gz -i ${PIP_INDEX_URL}

# 安装 Volcengine SDK（注意控制依赖版本）
RUN pip install --upgrade "volcengine-python-sdk[ark]" -i ${PIP_INDEX_URL}

# 🔧 修复依赖版本冲突（强制指定 httpx/httpcore/h11）
RUN pip install --force-reinstall \
    "httpx==0.27.2" \
    "httpcore==1.0.5" \
    "h11==0.14.0" -i ${PIP_INDEX_URL}

ENTRYPOINT ["/pynguin/pynguin-docker.sh"]
CMD []
